              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rollNumber\": \"2024100\",\n  \"name\": \"Aditya Patel\",\n  \"email\": \"aditya.patel@student.edutrack.com\",\n  \"phone\": \"9123456789\",\n  \"semester\": 3,\n  \"branch\": \"Computer Science\",\n  \"father\": \"Rajendra Patel\",\n  \"mother\": \"Sarina Patel\"\n}"
            },
