  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "teacher_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "teacher_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "student_id",
